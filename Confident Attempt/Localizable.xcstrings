    "help.tips.daily-limit" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine Gewohnheit kann entweder einmal pro Tag („normal“), mehrmals bis zu einer bestimmten Obergrenze („wiederholt“) oder so oft du möchtest („unbegrenzt“) erledigt werden."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A habit can be completed either once per day ('normal'), multiple times up to a certain limit ('repeated'), or as often as you like ('unlimited')."
          }
        }
      }
    },
    "help.tips.details" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clicke auf eine Gewohnheit, um weitere Details und Auswertungen anzuzeigen und festzulegen, wie oft diese Gewohnheit an den vergangenen Tagen ausgeführt wurde."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap on a habit to see more details and analytics and set the number of time this habit was completed on previous days."
          }
        }
      }
    },
    "help.tips.evaluation" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der restliche Text wird rot angezeigt, wenn die Anzahl der Erledigungen unter dem Mindestwert für den angegebenen Zeitraum liegt (beide Werte können in den Einstellungen konfiguriert werden), und grün, wenn die Anzahl der abgeschlossenen Aufgaben über dem Zielwert liegt. Andernfalls wird er gelb / orange angezeigt."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The remaining text is red if the number of completions is below the minimum for the given period (both of which can be configured in the settings), and green if the number of completions is above the goal. Otherwise, it is yellow / orange."
          }
        }
      }
    },
    "help.tips.evaluation-today" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Symbol auf der linken Seite ist grün, wenn die heutigen Erledigungen ausreichen, um das langfristige Ziel zu erreichen, sofern sie täglich wiederholt werden, und rot, wenn dies nicht der Fall ist."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The symbol on the left is green if today's completions are enough to reach the long-term goal if repeated daily, and red if this is not the case."
          }
        }
      }
    },
    "help.tips.first-day" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Auswertung einer bestimmten Gewohnheit beginnt erst an dem Tag, an dem sie angelegt wurde, oder an dem Tag, an dem sie zum ersten Mal erledigt wurde (je nachdem, was früher eintritt)."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The evaluation for any given habit only starts at the day it was created, or its first completion (whatever is earlier)"
          }
        }
      }
    },
    "help.tips.swipe" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wische nach rechts oder links, um die Anzahl der Male, die du eine Gewohnheit heute erledigt hast, zu erhöhen oder zu verringern."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Swipe right or left to increase or decrease the number of times you have completed a habit today."
          }
        }
      }
    },
