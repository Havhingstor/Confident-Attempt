    "settings.notifications.help.badge" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hinweis: Nach dem Versenden der Benachrichtigung und vor dem nächsten Öffnen der App zeigt das Badge alle Gewohnheiten an, unabhängig davon, wie oft sie in der Vergangenheit oder an diesem Tag erledigt wurden."
