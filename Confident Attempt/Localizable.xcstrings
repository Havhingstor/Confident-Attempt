        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Note: After the notification has been sent, before the app is opened the next time, the badge number will include all habits, regardless of their number of completions in the past or on that day"
          }
        }
      }
    },
    "settings.notifications.help.basic" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sendet zu Beginn eines Tages eine Benachrichtigung und zeigt auf dem Badge die Anzahl der Gewohnheiten an, die heute noch nicht genug erledigt wurden, um das langfristige Ziel zu erreichen."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sends a notification at the start of a day and sets the badge to the number of habits which don't yet have enough completions to reach the long-term goal."
