    "help.tips.details" : {
      "localizations" : {
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap on a habit to see more details and analytics and set the number of time this habit was completed on previous days."
          }
        }
      }
    },
    "help.tips.evaluation" : {
      "localizations" : {
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The remaining text is red if the number of completions is below the minimum for the given period (both of which can be configured in the settings), and green if the number of completions is above the goal. Otherwise, it is yellow."
          }
        }
      }
    },
    "help.tips.evaluation-today" : {
      "localizations" : {
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The symbol on the left is green if today's completions are enough to reach the long-term goal if repeated daily, and red if this is not the case."
          }
        }
      }
    },
    "help.tips.first-day" : {
      "localizations" : {
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The evaluation for any given habit only starts at the day it was created, or its first completion (whatever is earlier)"
          }
        }
      }
    },
    "help.tips.repetition" : {
      "localizations" : {
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A habit can be completed either once per day ('normal'), multiple times up to a certain limit ('repeated'), or as often as you like ('unlimited')."
          }
        }
      }
    },
    "help.tips.swipe" : {
      "localizations" : {
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Swipe right or left to increase or decrease the number of times you have completed a habit."
          }
        }
      }
    },
